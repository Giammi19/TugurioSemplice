<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

 <display-name>Tugurio Semplice</display-name>

<welcome-file-list>
	<welcome-file>index.jsp</welcome-file>
</welcome-file-list>

<!-- LoginController -->
<servlet>
    <servlet-name>LoginController</servlet-name>
    <servlet-class>Control.TugurioSemplice.LoginController</servlet-class>
</servlet>

<!-- LogoutController -->
<servlet>
    <servlet-name>LogoutController</servlet-name>
    <servlet-class>Control.TugurioSemplice.LogoutController</servlet-class>
</servlet>

<!-- SignInController -->
<servlet>
    <servlet-name>SignInController</servlet-name>
    <servlet-class>Control.TugurioSemplice.SignInController</servlet-class>
</servlet>
  
<!-- DisplayProductController -->
<servlet>
  	<servlet-name>DisplayProductController</servlet-name>
  	<servlet-class>Control.TugurioSemplice.DisplayProductController</servlet-class>
</servlet>

<!-- DeleteProductController -->
<servlet>
	<servlet-name>DeleteProductController</servlet-name>
	<servlet-class>Control.TugurioSemplice.Admin.DeleteProductController</servlet-class>
</servlet>

<!-- InsertProductController -->
<servlet>
	<servlet-name>InsertProductController</servlet-name>
	<servlet-class>Control.TugurioSemplice.Admin.InsertProductController</servlet-class>
</servlet>

<!-- UpdateProductController -->
<servlet>
	<servlet-name>UpdateProductController</servlet-name>
	<servlet-class>Control.TugurioSemplice.Admin.UpdateProductController</servlet-class>
</servlet>

<!-- DisplayProductCatalogue -->
<servlet>
	<servlet-name>DisplayProductCatalogue</servlet-name>
	<servlet-class>Control.TugurioSemplice.DisplayProductCatalogue</servlet-class>
</servlet>

<!-- CartController -->
<servlet>
	<servlet-name>CartController</servlet-name>
	<servlet-class>Control.TugurioSemplice.CartController</servlet-class>
</servlet>

<!-- RecuperoController -->
<servlet>
	<servlet-name>RecuperoController</servlet-name>
	<servlet-class>Control.TugurioSemplice.RecuperoController</servlet-class>
</servlet>

<!-- CheckoutController -->
<servlet>
	<servlet-name>CheckoutController</servlet-name>
	<servlet-class>Control.TugurioSemplice.CheckoutController</servlet-class>
</servlet>

<!-- OrdineController -->
<servlet>
	<servlet-name>OrdineController</servlet-name>
	<servlet-class>Control.TugurioSemplice.OrdineController</servlet-class>
</servlet>

<!-- ModificaUtenteController -->
<servlet>
	<servlet-name>ModificaUtenteController</servlet-name>
	<servlet-class>Control.TugurioSemplice.ModificaUtenteController</servlet-class>
</servlet>

<!-- ListaOrdineController -->
<servlet>
	<servlet-name>ListaOrdineController</servlet-name>
	<servlet-class>Control.TugurioSemplice.ListaOrdineController</servlet-class>
</servlet>

<!-- ListaUtentiController -->
<servlet>
	<servlet-name>ListaUtentiController</servlet-name>
	<servlet-class>Control.TugurioSemplice.Admin.ListaUtentiController</servlet-class>
</servlet>

<!-- FatturaController -->
<servlet>
	<servlet-name>FatturaController</servlet-name>
	<servlet-class>Control.TugurioSemplice.FatturaController</servlet-class>
</servlet>

<!-- DeleteUtenteController -->
<servlet>
	<servlet-name>DeleteUtenteController</servlet-name>
	<servlet-class>Control.TugurioSemplice.Admin.DeleteUtenteController</servlet-class>
</servlet>

<!-- PagamentoController -->
<servlet>
	<servlet-name>PagamentoController</servlet-name>
	<servlet-class>Control.TugurioSemplice.PagamentoController</servlet-class>
</servlet>

<!-- CartaCreditoController -->
<servlet>
	<servlet-name>CartaCreditoController</servlet-name>
	<servlet-class>Control.TugurioSemplice.CartaCreditoController</servlet-class>
</servlet>
<!-- RicercaProdotto -->
<servlet>
	<servlet-name>RicercaProdotto</servlet-name>
	<servlet-class>Control.TugurioSemplice.RicercaProdotto</servlet-class>
</servlet>

<!-- RicercaUtente -->
<servlet>
	<servlet-name>RicercaUtente</servlet-name>
	<servlet-class>Control.TugurioSemplice.Admin.RicercaUtente</servlet-class>
</servlet>

<servlet-mapping>
	<servlet-name>CartaCreditoController</servlet-name>
    <url-pattern>/CartaCreditoController</url-pattern>
</servlet-mapping>

<servlet-mapping>
	<servlet-name>DisplayProductCatalogue</servlet-name>
    <url-pattern>/product</url-pattern>
</servlet-mapping>

<servlet-mapping>
	<servlet-name>DisplayProductController</servlet-name>
    <url-pattern>/DisplayProductDetail</url-pattern>
</servlet-mapping>

<servlet-mapping>
	<servlet-name>LoginController</servlet-name>
    <url-pattern>/login</url-pattern>
</servlet-mapping>

<!-- Filters -->
  
  <filter>
  	<filter-name>AdminFiltro</filter-name>
  	<filter-class>Control.Filtri.AdminFiltro</filter-class>
  </filter>
  
  <filter>
  	<filter-name>UtenteLoggatoFiltro</filter-name>
  	<filter-class>Control.Filtri.UtenteLoggatoFiltro</filter-class>
  </filter>

<!-- Error Pages -->
<error-page>
    <error-code>404</error-code>
    <location>/ErrorPage/404.jsp</location>
</error-page>

<error-page>
    <error-code>500</error-code>
    <location>/ErrorPage/500.jsp</location>
</error-page>

<error-page>
    <error-code>403</error-code>
    <location>/ErrorPage/403.jsp</location>
</error-page>

</web-app>